<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="15.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Import Project="$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props" Condition="Exists('$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props')" />
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">AnyCPU_Prefer32</Configuration>
    <Platform Condition=" '$(Platform)' == '' ">AnyCPU</Platform>
    <ProjectGuid>{7E2C3D2E-0AF7-4255-B335-CADF33F7C8D8}</ProjectGuid>
    <OutputType>Exe</OutputType>
    <RootNamespace>DNFConsoleMemDemo</RootNamespace>
    <AssemblyName>DNFConsoleMemDemo</AssemblyName>
    <TargetFrameworkVersion>v4.8</TargetFrameworkVersion>
    <FileAlignment>512</FileAlignment>
    <AutoGenerateBindingRedirects>true</AutoGenerateBindingRedirects>
    <Deterministic>true</Deterministic>
  </PropertyGroup>
  <!-- ═══════════════════════════════════════════════════════════════
       Configuration 1: Any CPU + Prefer 32-bit  (DEFAULT in VS!)
       This is the configuration that catches people off guard.
       Even on a 64-bit OS, the process runs as 32-bit, capping
       the managed heap at ~1.5 GB.
       ═══════════════════════════════════════════════════════════════ -->
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'AnyCPU_Prefer32|AnyCPU' ">
    <PlatformTarget>AnyCPU</PlatformTarget>
    <Prefer32Bit>false</Prefer32Bit>
    <Optimize>true</Optimize>
    <OutputPath>bin\AnyCPU_Prefer32\</OutputPath>
    <DefineConstants>TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>
  <!-- ═══════════════════════════════════════════════════════════════
       Configuration 2: Any CPU WITHOUT Prefer 32-bit
       On a 64-bit OS this runs as a 64-bit process with access
       to the full virtual address space.
       ═══════════════════════════════════════════════════════════════ -->
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'AnyCPU_No32|AnyCPU' ">
    <PlatformTarget>AnyCPU</PlatformTarget>
    <Prefer32Bit>false</Prefer32Bit>
    <Optimize>true</Optimize>
    <OutputPath>bin\AnyCPU_No32\</OutputPath>
    <DefineConstants>TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>
  <!-- ═══════════════════════════════════════════════════════════════
       Configuration 3: Explicit x86
       Always 32-bit, same ~1.5 GB ceiling as Prefer32Bit.
       ═══════════════════════════════════════════════════════════════ -->
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release_x86|x86' ">
    <PlatformTarget>x86</PlatformTarget>
    <Prefer32Bit>false</Prefer32Bit>
    <Optimize>true</Optimize>
    <OutputPath>bin\x86\Release_x86\</OutputPath>
    <DefineConstants>TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>
  <!-- ═══════════════════════════════════════════════════════════════
       Configuration 4: Explicit x64
       Always 64-bit — full address space, limited only by RAM.
       ═══════════════════════════════════════════════════════════════ -->
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release_x64|x64' ">
    <PlatformTarget>x64</PlatformTarget>
    <Prefer32Bit>false</Prefer32Bit>
    <Optimize>true</Optimize>
    <OutputPath>bin\x64\Release_x64\</OutputPath>
    <DefineConstants>TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>
  <!-- Keep Debug for quick iteration in VS -->
  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|AnyCPU' ">
    <PlatformTarget>AnyCPU</PlatformTarget>
    <Prefer32Bit>true</Prefer32Bit>
    <DebugSymbols>true</DebugSymbols>
    <DebugType>full</DebugType>
    <Optimize>false</Optimize>
    <OutputPath>bin\Debug\</OutputPath>
    <DefineConstants>DEBUG;TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>
  <ItemGroup>
    <Reference Include="System" />
    <Reference Include="System.Core" />

    <Reference Include="System.Xml.Linq" />
    <Reference Include="System.Data.DataSetExtensions" />
    <Reference Include="Microsoft.CSharp" />
    <Reference Include="System.Data" />
    <Reference Include="System.Net.Http" />
    <Reference Include="System.Xml" />
  </ItemGroup>
  <ItemGroup>
    <Compile Include="Program.cs" />
    <Compile Include="Properties\AssemblyInfo.cs" />
  </ItemGroup>
  <ItemGroup>
    <None Include="App.config" />
  </ItemGroup>
  <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets" />
</Project>